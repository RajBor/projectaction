{
  "cli": {
    "version": ">= 7.8.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://your-dealnector-host.example.com",
        "EXPO_PUBLIC_API_KEY": ""
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://your-dealnector-host.example.com",
        "EXPO_PUBLIC_API_KEY": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
